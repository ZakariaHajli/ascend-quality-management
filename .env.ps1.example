# Copy to .env.ps1 (gitignored) and fill in. Source it with:  . .\.env.ps1
# Find Org/Account: SELECT CURRENT_ORGANIZATION_NAME(), CURRENT_ACCOUNT_NAME();

$Org       = "MYORG"
$Account   = "MYACCOUNT"
$User      = "MYUSER"
$Password  = "PUT-YOUR-PASSWORD-HERE"
$AdminRole = "ACCOUNTADMIN"     # provisions infra (Terraform)

# ── Terraform (provision dev/uat/prod) ──────────────────────────────────────
$env:TF_VAR_snowflake_organization_name = $Org
$env:TF_VAR_snowflake_account_name      = $Account
$env:TF_VAR_snowflake_user              = $User
$env:TF_VAR_snowflake_password          = $Password
$env:TF_VAR_snowflake_role              = $AdminRole

# ── dbt (role/warehouse/database are per-target in profiles.yml) ─────────────
$env:ASCEND_SF_ACCOUNT  = "$Org-$Account"
$env:ASCEND_SF_USER     = $User
$env:ASCEND_SF_PASSWORD = $Password

Write-Host "Quality Management environment loaded (org '$Org', account '$Account')." -ForegroundColor Green
